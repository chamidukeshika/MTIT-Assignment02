{
  "info": {
    "name": "MTIT Assignment 02 API Collection",
    "description": "Working CRUD requests for the six backend microservices through the API gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gatewayUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Product Service",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "{{gatewayUrl}}/api/products"
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "url": "{{gatewayUrl}}/api/products/1"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monitor\",\n  \"category\": \"Electronics\",\n  \"description\": \"27 inch IPS monitor\",\n  \"price\": 85000.0,\n  \"status\": \"AVAILABLE\"\n}"
            },
            "url": "{{gatewayUrl}}/api/products"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro\",\n  \"category\": \"Electronics\",\n  \"description\": \"Updated laptop model\",\n  \"price\": 275000.0,\n  \"status\": \"AVAILABLE\"\n}"
            },
            "url": "{{gatewayUrl}}/api/products/1"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{gatewayUrl}}/api/products/3"
          }
        }
      ]
    },
